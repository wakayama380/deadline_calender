{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deadline Calender",
  "version": "0.1.0",
  "identifier": "com.tashi.deadlinecalender",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Deadline Calender",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
